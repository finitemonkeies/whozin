{
  "rewrites": [
    {
      "source": "/event/(.*)",
      "destination": "/api/event?id=$1"
    },
    {
      "source": "/share/(.*)",
      "destination": "/api/share?handle=$1"
    },
    {
      "source": "/i/(.*)",
      "destination": "/api/invite?token=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
