# Frontend (safe to expose in browser builds)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SITE_URL=https://whozin.app
VITE_PHONE_AUTH_ENABLED=false
VITE_SPOTIFY_RECOMMENDATIONS_ENABLED=false
VITE_SURFACE_INGESTED_SOURCES=false
VITE_KILL_SWITCH_RSVP_WRITES=false
VITE_KILL_SWITCH_INVITES=false
VITE_KILL_SWITCH_FRIEND_ADDS=false
# Optional Week 2 Explore provider key (public API key usage)
# VITE_TICKETMASTER_API_KEY=YOUR_TICKETMASTER_KEY

# Spotify OAuth is configured in Supabase Auth Providers (no frontend secret required).
# Required provider scope for personalized taste sync: user-top-read

# Edge Function env vars (set these in Supabase Dashboard, not frontend hosting)
# CORS_ORIGINS=https://whozin.app,https://www.whozin.app,http://localhost:5173
# SIGNUP_ADMIN_TOKEN=GENERATE_A_LONG_RANDOM_SECRET
